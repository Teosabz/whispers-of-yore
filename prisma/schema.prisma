generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Story {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  text       String
  region     String
  category   String
  language   String
  sourceUrl  String?
  coverImage String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  authorId   Int?
  author     User?    @relation(fields: [authorId], references: [id])
  tags       Tag[]    @relation("StoryTags")
}



model Tag {
  id      Int      @id @default(autoincrement())
  name    String   @unique

  stories Story[]
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique

  contributions Story[]  @relation("UserContributions")
}
